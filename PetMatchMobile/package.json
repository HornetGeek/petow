    "react-native-phone-number-input": "^2.1.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-safe-area-context": "^4.10.8",
    "react-native-screens": "^3.31.1",
    "react-native-share": "^10.0.2",
    "react-native-svg": "^14.1.0",
