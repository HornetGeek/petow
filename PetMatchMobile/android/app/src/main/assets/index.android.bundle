0642\u0628\u0644 \u0625\u0646\u0634\u0627\u0621 \u0627\u0644\u062d\u0633\u0627\u0628 \u0623\u0648 \u0627\u0644\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0641\u064a \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u062e\u062f\u0645\u0627\u062a\u0646\u0627."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"1. \u0627\u0644\u062a\u0633\u062c\u064a\u0644 \u0648\u0627\u0644\u062d\u0633\u0627\u0628"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u064a\u062c\u0628 \u0623\u0646 \u062a\u0643\u0648\u0646 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0642\u062f\u0645\u0647\u0627 \u062f\u0642\u064a\u0642\u0629 \u0648\u0645\u062d\u062f\u062b\u0629. \u0623\u0646\u062a \u0645\u0633\u0624\u0648\u0644 \u0639\u0646 \u062d\u0645\u0627\u064a\u0629 \u0628\u064a\u0627\u0646\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0643 \u0648\u0639\u0646 \u0623\u064a \u0646\u0634\u0627\u0637 \u064a\u062d\u062f\u062b \u0645\u0646 \u062e\u0644\u0627\u0644 \u062d\u0633\u0627\u0628\u0643. \u064a\u062d\u0642 \u0644\u0646\u0627 \u062a\u0639\u0644\u064a\u0642 \u0623\u0648 \u0625\u063a\u0644\u0627\u0642 \u0627\u0644\u062d\u0633\u0627\u0628\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0646\u062a\u0647\u0643 \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0623\u0648 \u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u0639\u0645\u0648\u0644 \u0628\u0647\u0627."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"2. \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062e\u062f\u0645\u0629"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u064a\u0648\u0641\u0631 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0645\u0646\u0635\u0629 \u0644\u0644\u062a\u0648\u0627\u0635\u0644 \u0628\u064a\u0646 \u0645\u0627\u0644\u0643\u064a \u0627\u0644\u062d\u064a\u0648\u0627\u0646\u0627\u062a \u0627\u0644\u0623\u0644\u064a\u0641\u0629. \u064a\u064f\u062d\u0638\u0631 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062e\u062f\u0645\u0629 \u0644\u0623\u064a \u063a\u0631\u0636 \u0645\u062e\u0627\u0644\u0641 \u0644\u0644\u0642\u0627\u0646\u0648\u0646\u060c \u0623\u0648 \u0625\u0631\u0633\u0627\u0644 \u0645\u062d\u062a\u0648\u0649 \u0645\u0633\u064a\u0621\u060c \u0623\u0648 \u0627\u0646\u062a\u062d\u0627\u0644 \u0634\u062e\u0635\u064a\u0629 \u0627\u0644\u063a\u064a\u0631\u060c \u0623\u0648 \u0627\u0644\u0625\u0636\u0631\u0627\u0631 \u0628\u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0627\u0644\u0622\u062e\u0631\u064a\u0646. \u064a\u062d\u062a\u0641\u0638 PetMatch \u0628\u0627\u0644\u062d\u0642 \u0641\u064a \u0625\u0632\u0627\u0644\u0629 \u0623\u064a \u0645\u062d\u062a\u0648\u0649 \u0645\u062e\u0627\u0644\u0641 \u062f\u0648\u0646 \u0625\u0634\u0639\u0627\u0631."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"3. \u0627\u0644\u0645\u062d\u062a\u0648\u0649"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u0623\u0646\u062a \u062a\u062d\u062a\u0641\u0638 \u0628\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0630\u064a \u062a\u0636\u064a\u0641\u0647\u060c \u0644\u0643\u0646\u0643 \u062a\u0645\u0646\u062d PetMatch \u062a\u0631\u062e\u064a\u0635\u064b\u0627 \u063a\u064a\u0631 \u062d\u0635\u0631\u064a \u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645\u0647 \u0648\u062a\u0634\u063a\u064a\u0644\u0647 \u0636\u0645\u0646 \u0646\u0637\u0627\u0642 \u0627\u0644\u062a\u0637\u0628\u064a\u0642. \u0623\u0646\u062a \u0645\u0633\u0624\u0648\u0644 \u0639\u0646 \u0627\u0644\u062a\u0623\u0643\u062f \u0645\u0646 \u0623\u0646 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0644\u0627 \u064a\u0646\u062a\u0647\u0643 \u062d\u0642\u0648\u0642 \u0623\u064a \u0637\u0631\u0641 \u062b\u0627\u0644\u062b."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"4. \u062d\u062f\u0648\u062f \u0627\u0644\u0645\u0633\u0624\u0648\u0644\u064a\u0629"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u064a\u0642\u062f\u0645 PetMatch \u062e\u062f\u0645\u0627\u062a\u0647 \"\u0643\u0645\u0627 \u0647\u064a\" \u062f\u0648\u0646 \u0623\u064a \u0636\u0645\u0627\u0646\u0627\u062a \u0635\u0631\u064a\u062d\u0629 \u0623\u0648 \u0636\u0645\u0646\u064a\u0629. \u0644\u0627 \u0646\u062a\u062d\u0645\u0644 \u0645\u0633\u0624\u0648\u0644\u064a\u0629 \u0623\u064a \u0623\u0636\u0631\u0627\u0631 \u0645\u0628\u0627\u0634\u0631\u0629 \u0623\u0648 \u063a\u064a\u0631 \u0645\u0628\u0627\u0634\u0631\u0629 \u062a\u0646\u0634\u0623 \u0639\u0646 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0623\u0648 \u0627\u0644\u0627\u0639\u062a\u0645\u0627\u062f \u0639\u0644\u0649 \u0623\u064a \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0645\u0642\u062f\u0645\u0629 \u0639\u0628\u0631\u0647. \u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0627\u0644\u0622\u062e\u0631\u064a\u0646 \u0628\u062d\u0630\u0631 \u0648\u0627\u062a\u062e\u0630 \u0627\u0644\u062a\u062f\u0627\u0628\u064a\u0631 \u0627\u0644\u0644\u0627\u0632\u0645\u0629 \u0644\u062d\u0645\u0627\u064a\u0629 \u0646\u0641\u0633\u0643 \u0648\u062d\u064a\u0648\u0627\u0646\u0643 \u0627\u0644\u0623\u0644\u064a\u0641."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"5. \u0627\u0644\u062a\u0639\u062f\u064a\u0644\u0627\u062a \u0648\u0627\u0644\u0625\u0646\u0647\u0627\u0621"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u064a\u062c\u0648\u0632 \u0644\u0646\u0627 \u062a\u0639\u062f\u064a\u0644 \u0623\u0648 \u062a\u062d\u062f\u064a\u062b \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0641\u064a \u0623\u064a \u0648\u0642\u062a. \u0633\u064a\u062a\u0645 \u0625\u062e\u0637\u0627\u0631\u0643 \u0628\u0627\u0644\u062a\u0639\u062f\u064a\u0644\u0627\u062a \u0627\u0644\u062c\u0648\u0647\u0631\u064a\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0623\u0648 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a. \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0633\u062a\u062e\u062f\u0627\u0645\u0643 \u0644\u0644\u062e\u062f\u0645\u0629 \u0628\u0639\u062f \u0627\u0644\u062a\u062d\u062f\u064a\u062b \u064a\u0639\u0646\u064a \u0645\u0648\u0627\u0641\u0642\u062a\u0643 \u0639\u0644\u0649 \u0627\u0644\u0634\u0631\u0648\u0637 \u0627\u0644\u0645\u0639\u062f\u0644\u0629. \u0643\u0645\u0627 \u064a\u062d\u0642 \u0644\u0643 \u0623\u0648 \u0644\u0646\u0627 \u0625\u0646\u0647\u0627\u0621 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062e\u062f\u0645\u0629 \u0641\u064a \u0623\u064a \u0648\u0642\u062a."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"6. \u0627\u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0639\u0645\u0648\u0644 \u0628\u0647\u0627"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u062a\u062e\u0636\u0639 \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u062a\u064f\u0641\u0633\u0631 \u0648\u0641\u0642 \u0627\u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0639\u0645\u0648\u0644 \u0628\u0647\u0627 \u0641\u064a \u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0645\u0635\u0631 \u0627\u0644\u0639\u0631\u0628\u064a\u0629\u060c \u0645\u0639 \u0645\u0631\u0627\u0639\u0627\u0629 \u0627\u0644\u0627\u062e\u062a\u0635\u0627\u0635 \u0627\u0644\u0642\u0636\u0627\u0626\u064a \u0644\u0644\u0645\u062d\u0627\u0643\u0645 \u0627\u0644\u0645\u062d\u0644\u064a\u0629 \u0641\u064a \u062d\u0627\u0644\u0629 \u0627\u0644\u0646\u0632\u0627\u0639\u0627\u062a."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"7. \u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u0644\u0623\u064a \u0623\u0633\u0626\u0644\u0629 \u0623\u0648 \u0645\u0644\u0627\u062d\u0638\u0627\u062a \u062d\u0648\u0644 \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637\u060c \u064a\u0631\u062c\u0649 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639 \u0641\u0631\u