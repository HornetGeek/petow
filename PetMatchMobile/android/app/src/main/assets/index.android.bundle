27\u0646\u0627\u062a \u0627\u062e\u062a\u064a\u0627\u0631\u064a\u0629: \u0631\u0642\u0645 \u0627\u0644\u0647\u0627\u062a\u0641 \u0623\u0648 \u0627\u0644\u0645\u0648\u0642\u0639 \u0641\u064a \u062d\u0627\u0644\u0629 \u0627\u062e\u062a\u064a\u0627\u0631\u0643 \u062a\u0641\u0639\u064a\u0644 \u0647\u0630\u0647 \u0627\u0644\u0645\u064a\u0632\u0627\u062a."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"2. \u0643\u064a\u0641\u064a\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u0646\u0633\u062a\u062e\u062f\u0645 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0645\u0646 \u0623\u062c\u0644: \u0625\u0646\u0634\u0627\u0621 \u0627\u0644\u062d\u0633\u0627\u0628 \u0648\u0625\u062f\u0627\u0631\u062a\u0647\u060c \u062a\u0642\u062f\u064a\u0645 \u062e\u062f\u0645\u0627\u062a \u0645\u0637\u0627\u0628\u0642\u0629 \u0627\u0644\u062d\u064a\u0648\u0627\u0646\u0627\u062a \u0627\u0644\u0623\u0644\u064a\u0641\u0629\u060c \u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0623\u062f\u0627\u0621 \u0648\u0627\u0644\u062a\u062c\u0631\u0628\u0629\u060c \u0625\u0631\u0633\u0627\u0644 \u0625\u0634\u0639\u0627\u0631\u0627\u062a \u0645\u062a\u0639\u0644\u0642\u0629 \u0628\u0627\u0644\u0646\u0634\u0627\u0637 \u062f\u0627\u062e\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u060c \u0648\u0627\u0644\u0631\u062f \u0639\u0644\u0649 \u0627\u0633\u062a\u0641\u0633\u0627\u0631\u0627\u062a \u0627\u0644\u062f\u0639\u0645."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"3. \u0645\u0634\u0627\u0631\u0643\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u0644\u0627 \u0646\u0628\u064a\u0639 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629. \u0642\u062f \u0646\u0634\u0627\u0631\u0643 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0645\u062d\u062f\u0648\u062f\u0629 \u0645\u0639 \u0645\u0632\u0648\u062f\u064a \u062e\u062f\u0645\u0629 \u0645\u0648\u062b\u0648\u0642\u064a\u0646 \u064a\u0633\u0627\u0639\u062f\u0648\u0646\u0646\u0627 \u0641\u064a \u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 (\u0645\u062b\u0644 \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0627\u0633\u062a\u0636\u0627\u0641\u0629 \u0648\u0627\u0644\u062a\u062d\u0644\u064a\u0644\u0627\u062a) \u0645\u0639 \u0627\u0644\u062a\u0632\u0627\u0645\u0647\u0645 \u0627\u0644\u062a\u0639\u0627\u0642\u062f\u064a \u0628\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a. \u0633\u0646\u0644\u062a\u0632\u0645 \u0628\u0623\u064a \u0627\u0644\u062a\u0632\u0627\u0645\u0627\u062a \u0642\u0627\u0646\u0648\u0646\u064a\u0629 \u0628\u0627\u0644\u062a\u0635\u0631\u064a\u062d \u0639\u0646 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0625\u0630\u0627 \u0637\u064f\u0644\u0628 \u0645\u0646\u0627 \u0630\u0644\u0643 \u0628\u0645\u0648\u062c\u0628 \u0627\u0644\u0642\u0627\u0646\u0648\u0646."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"4. \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0638 \u0628\u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u0646\u062d\u062a\u0641\u0638 \u0628\u0628\u064a\u0627\u0646\u0627\u062a \u062d\u0633\u0627\u0628\u0643 \u0637\u0627\u0644\u0645\u0627 \u0643\u0627\u0646 \u062d\u0633\u0627\u0628\u0643 \u0646\u0634\u0637\u064b\u0627. \u0641\u064a \u062d\u0627\u0644 \u0637\u0644\u0628 \u062d\u0630\u0641 \u0627\u0644\u062d\u0633\u0627\u0628 \u0623\u0648 \u0625\u063a\u0644\u0627\u0642\u0647 \u0646\u0642\u0648\u0645 \u0628\u0625\u0632\u0627\u0644\u0629 \u0623\u0648 \u0625\u062e\u0641\u0627\u0621 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u062e\u0644\u0627\u0644 \u0645\u062f\u0629 \u0632\u0645\u0646\u064a\u0629 \u0645\u0639\u0642\u0648\u0644\u0629 \u0645\u0627 \u0644\u0645 \u064a\u062a\u0637\u0644\u0628 \u0627\u0644\u0642\u0627\u0646\u0648\u0646 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0638 \u0628\u0647\u0627 \u0644\u0641\u062a\u0631\u0629 \u0623\u0637\u0648\u0644."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"5. \u062d\u0642\u0648\u0642\u0643"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u064a\u0645\u0643\u0646\u0643 \u062a\u062d\u062f\u064a\u062b \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u0643\u060c \u0637\u0644\u0628 \u0646\u0633\u062e\u0629 \u0645\u0646 \u0628\u064a\u0627\u0646\u0627\u062a\u0643\u060c \u0623\u0648 \u062d\u0630\u0641 \u062d\u0633\u0627\u0628\u0643 \u0645\u0646 \u062f\u0627\u062e\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642. \u0644\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0645\u062a\u0639\u0644\u0642\u0629 \u0628\u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u064a\u0631\u062c\u0649 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a support@petow.app."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"6. \u0627\u0644\u0623\u0645\u0627\u0646"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u0646\u0633\u062a\u062e\u062f\u0645 \u062a\u062f\u0627\u0628\u064a\u0631 \u062a\u0642\u0646\u064a\u0629 \u0648\u0625\u062f\u0627\u0631\u064a\u0629 \u0645\u0646\u0627\u0633\u0628\u0629 \u0644\u062d\u0645\u0627\u064a\u0629 \u0628\u064a\u0627\u0646\u0627\u062a\u0643\u060c \u0648\u0645\u0639 \u0630\u0644\u0643 \u0641\u0625\u0646 \u0623\u064a \u0646\u0642\u0644 \u0639\u0628\u0631 \u0627\u0644\u0625\u0646\u062a\u0631\u0646\u062a \u0644\u0627 \u064a\u0645\u0643\u0646 \u0623\u0646 \u064a\u0643\u0648\u0646 \u0622\u0645\u0646\u064b\u0627 \u0628\u0646\u0633\u0628\u0629 100\u066a. \u0633\u0646\u0642\u0648\u0645 \u0628\u0625\u062e\u0637\u0627\u0631\u0643 \u0628\u0623\u064a \u062e\u0631\u0642 \u0623\u0645\u0646\u064a \u064a\u0624\u062b\u0631 \u0639\u0644\u0649 \u062e\u0635\u0648\u0635\u064a\u062a\u0643 \u0648\u0641\u0642 \u0627\u0644\u0645\u062a\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"7. \u0627\u0644\u062a\u062d\u062f\u064a\u062b\u0627\u062a"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u0642\u062f \u0646\u0642\u0648\u0645 \u0628\u062a\u062d\u062f\u064a\u062b \u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0645\u0646 \u0648\u0642\u062a \u0644\u0622\u062e\u0631. \u0633\u0646\u064f\u062e\u0637\u0631\u0643 \u062f\u0627\u062e\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0623\u0648 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u0639\u0646\u062f \u0625\u062c\u0631\u0627\u0621 \u0623\u064a \u062a\u063a\u064a\u064a\u0631\u0627\u062a \u062c\u0648\u0647\u0631\u064a\u0629\u060c \u0648\u0633\u064a\u0635\u0628\u062d \u0627\u0644\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0641\u064a \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0639\u0642\u0628 \u0627\u0644\u062a\u062d\u062f\u064a\u062b \u0645\u0648\u0627\u0641\u0642\u0629 \u0636\u0645\u0646\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u0645\u0639\u062f\u0644\u0629."}),(0,l.jsx)(n.Text,{style:o.sectionTitle,children:"8. \u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627"}),(0,l.jsx)(n.Text,{style:o.paragraph,children:"\u0644\u0623\u064a \u0623\u0633\u0626\u0644\u0629 \u062d\u0648\u0644 \u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629\u060c \u062a\u0648\u0627\u0635\u0644 \u0645\u0639 \u0641\u0631\u064a\u0642 PetMatch \u0639\u0644\u0649 support@petow.app."})]})]})}},950,[1,17,19,218]);
